# SteelMind Backend — Development Environment
# COPY this file to .env and fill in your actual values

# ─── REQUIRED: Add your Groq API key ─────────────────────────────────────────
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# ─── Database (Docker defaults) ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://steelmind:steelmind_pass@localhost:5432/steelmind_db
DATABASE_URL_SYNC=postgresql://steelmind:steelmind_pass@localhost:5432/steelmind_db

INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=steelmind-influx-token-dev
INFLUX_ORG=steelmind_org
INFLUX_BUCKET=sensor_data

REDIS_URL=redis://localhost:6379/0

# ─── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=steelmind_dev_secret_key_change_in_production_32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ─── ChromaDB / RAG ───────────────────────────────────────────────────────────
CHROMA_PATH=./data/chroma_db
CHROMA_COLLECTION=steelmind_knowledge
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=5

# ─── Alert thresholds ─────────────────────────────────────────────────────────
ANOMALY_WARNING_THRESHOLD=50
ANOMALY_CRITICAL_THRESHOLD=75
RUL_WARNING_DAYS=30
RUL_CRITICAL_DAYS=7

# ─── Optional notifications ───────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SLACK_WEBHOOK_URL=
