# ─── LLM ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Available Groq models:
# llama-3.3-70b-versatile   (best quality, use for main copilot)
# llama-3.1-8b-instant      (fast, use for quick classifications)
# mixtral-8x7b-32768        (long context, use for document analysis)

# ─── Databases ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://steelmind:steelmind_pass@localhost:5432/steelmind_db
DATABASE_URL_SYNC=postgresql://steelmind:steelmind_pass@localhost:5432/steelmind_db

INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=steelmind-influx-token-dev
INFLUX_ORG=steelmind_org
INFLUX_BUCKET=sensor_data

REDIS_URL=redis://localhost:6379/0

# ─── App ─────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_in_production_use_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ─── ChromaDB ────────────────────────────────────────────────────────────
CHROMA_PATH=./data/chroma_db
CHROMA_COLLECTION=steelmind_knowledge

# ─── RAG ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=nomic-embed-text
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=5

# ─── Alert Thresholds ────────────────────────────────────────────────────
ANOMALY_WARNING_THRESHOLD=50
ANOMALY_CRITICAL_THRESHOLD=75
RUL_WARNING_DAYS=30
RUL_CRITICAL_DAYS=7

# ─── Notifications (optional) ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
